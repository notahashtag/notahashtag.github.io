// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/dotnet
{
	"name": "C# (.NET)",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	// "image": "mcr.microsoft.com/devcontainers/dotnet:2-10.0-noble"
	"build": {
        "dockerfile": "./Dockerfile",
        "context": "."
    },

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [5157, 7180],
	"portsAttributes": {
			"7180": {
				"protocol": "https"
			}
	},

	// Use 'postCreateCommand' to run commands after the container is created.
	"waitFor": "postCreateCommand",
	"postCreateCommand": ".devcontainer/postCreateScript.sh",
	"shutdownAction": "stopContainer",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csdevkit",
				"humao.rest-client",
				"stoplight.spectral",
				"microsoft-aspire.aspire-vscode"
			]//,
			// "settings": {
			// 	"dotnet.server.dotnetPath": "/usr/bin/dotnet"//,
			// }
		}
	},

	"mounts": [
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
		"source=nuget-cache,target=/home/vscode/.nuget/packages,type=volume"
	]

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
